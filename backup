}

textarea::-moz-placeholder {
  opacity: 1;
  color: #9ca3af;
}

textarea::placeholder {
  opacity: 1;
  color: #9ca3af;
}

audio,
canvas,
embed,
object,
svg,
video {
  display: block;
  vertical-align: middle;
}
video {
  max-width: 100%;
